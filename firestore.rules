rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: customers
    // Fields: id, name, birthDate, phone, whatsapp, email, document, address
    //
    // Collection: orders
    // Fields: id, osNumber, customerId, equipment, checklist, defect, status, etc.
    //
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
          (request.auth.token.email == "gabriel.vas.deby@gmail.com" && request.auth.token.email_verified == true));
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['companyName', 'email', 'role', 'createdAt']) &&
             data.companyName is string && data.companyName.size() > 0 &&
             data.email is string && data.email.size() > 0 &&
             data.role in ['admin', 'user'] &&
             data.createdAt is string;
    }

    function isValidProfile(data) {
      return data.keys().hasAll(['name', 'type', 'role']) &&
             data.name is string && data.name.size() > 0 &&
             data.type in ['ADM', 'Financeiro', 'Técnico', 'Atendente'] &&
             data.role is string;
    }

    match /test/{docId} {
      allow read, write: if isAuthenticated();
    }

    match /customers/{customerId} {
      allow read, write: if isAuthenticated();
    }

    match /orders/{orderId} {
      allow read, write: if isAuthenticated();
    }

    match /transactions/{transactionId} {
      allow read, write: if isAuthenticated();
    }

    match /products/{productId} {
      allow read, write: if isAuthenticated();
    }

    match /productHistory/{historyId} {
      allow read, write: if isAuthenticated();
    }

    match /sales/{saleId} {
      allow read, write: if isAuthenticated();
    }

    match /cashSessions/{sessionId} {
      allow read, write: if isAuthenticated();
    }

    match /expenses/{expenseId} {
      allow read, write: if isAuthenticated();
    }

    match /receivables/{receivableId} {
      allow read, write: if isAuthenticated();
    }

    match /tasks/{taskId} {
      allow read, write: if isAuthenticated();
    }
    
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
      
      match /profiles/{profileId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidProfile(request.resource.data);
        allow update: if isOwner(userId) && isValidProfile(request.resource.data);
        allow delete: if isOwner(userId);
      }
    }
  }
}
